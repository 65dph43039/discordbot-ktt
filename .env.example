# Required
DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id

# Optional: set to a specific guild ID for instant command registration during development.
# Leave blank to register global commands (takes up to 1 hour to propagate).
GUILD_ID=

# Comma-separated role IDs that are allowed to use capture commands.
# Admins and the guild owner always have access regardless of this setting.
CAPTOR_ROLE_IDS=

# Comma-separated role IDs that are immune from being captured.
# Admins and the guild owner are always immune regardless of this setting.
IMMUNE_ROLE_IDS=

# Channel ID where punishment actions are logged.
AUDIT_CHANNEL_ID=

# Path to the SQLite database file (default: ./data/bot.db)
DB_PATH=./data/bot.db

# Logging level: error | warn | info | debug (default: info)
LOG_LEVEL=info
